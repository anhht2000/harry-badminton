    "next": "14.2.30",
    "next-auth": "5.0.0-beta.31",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "drizzle-kit": "0.31.10",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.30",
    "postcss": "8.4.39",
    "tailwindcss": "3.4.6",
